# Port du serveur HTTP
PORT=8090

# Secret de signature des sessions (générer une chaîne aléatoire longue en prod)
SESSION_SECRET=change-moi-en-production

# --- OAuth Google ("Se connecter avec Google", seul mode d'authentification) ---
# Console Cloud > API et services > Identifiants > Créer des identifiants >
# ID client OAuth > Application Web. Ajouter GOOGLE_OAUTH_REDIRECT_URI dans
# les "URI de redirection autorisés" du client OAuth.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8090/api/auth/google/callback

# --- Google Workspace Admin SDK (gestion des Google Groups) ---
# Nécessite un compte de service avec délégation domaine-wide sur un domaine
# Google Workspace (les Google Groups ne sont PAS disponibles sur un compte
# Gmail personnel gratuit). Voir README.md > "Configuration Google" pour le
# détail de la procédure (Console Cloud > IAM > compte de service > clé JSON).
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json
GOOGLE_ADMIN_IMPERSONATE_EMAIL=admin@votredomaine.com
GOOGLE_GROUPS_DOMAIN=votredomaine.com

# --- Google Play Developer API (Android Publisher - lecture des avis) ---
# Même compte de service, ajouté comme utilisateur "Voir les infos financières"
# (ou "Admin") dans Play Console > Utilisateurs et autorisations, avec accès
# à l'API activé (Play Console > Configuration de l'API).
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY_PATH=./google-play-service-account.json

# Si l'une des variables Google ci-dessus est absente, le service concerné
# démarre quand même en MODE DEV (OAuth via /api/auth/dev-login, Google
# Groups / Play Reviews simulés en mémoire) pour permettre de tester tout
# le parcours (score, paliers, cron) sans compte Google réel.
